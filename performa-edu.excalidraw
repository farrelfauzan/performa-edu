      "seed": 527153915,
      "version": 1903,
      "versionNonce": 516862211,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1760499474664,
      "link": null,
      "locked": false,
      "text": "What happend Here?\n- Attendance use redis for queueing process \n  when student doing attendance\n- Exam use redis for queueing process \n   when student submit the assignment\n- Assignment use redis for queueing process\n   when student submit the assignment\n- Grade use redis for generate the report\n  with PDF File, use queue for more seamless \n  async process",
      "fontSize": 8.597108004641612,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What happend Here?\n- Attendance use redis for queueing process \n  when student doing attendance\n- Exam use redis for queueing process \n   when student submit the assignment\n- Assignment use redis for queueing process\n   when student submit the assignment\n- Grade use redis for generate the report\n  with PDF File, use queue for more seamless \n  async process",
      "autoResize": true,
      "lineHeight": 1.25
    },
