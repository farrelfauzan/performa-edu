    {
      "id": "SJttW0_ufPCCFcD-5ny04",
      "type": "text",
      "x": 691.6941370249543,
      "y": 2074.6298739325744,
      "width": 212.6019287109375,
      "height": 107.46385005802014,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e03131",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
