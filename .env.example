# Database Configuration
# Replace with your actual database credentials
DATABASE_URL="postgresql://username:password@localhost:5432/performa_edu_db?schema=public"

# Alternative database URL formats:
# For local development: "postgresql://postgres:password@localhost:5432/performa_edu_dev"
# For Docker: "postgresql://postgres:password@postgres:5432/performa_edu_db"
# For cloud (example): "postgresql://user:pass@host:5432/dbname?sslmode=require"

# Prisma Configuration
PRISMA_CLI_QUERY_ENGINE_TYPE=binary

# Application Environment
NODE_ENV=development
PORT=3000

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Minio Configuration (for local development)
MINIO_HOST=
MINIO_PORT=
MINIO_USER=
MINIO_PASSWORD=
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=content-media

# Optional: Redis for caching/sessions
# REDIS_URL=redis://localhost:6379

# Optional: Email configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: File upload configuration
# MAX_FILE_SIZE=10485760  # 10MB
# UPLOAD_DIR=uploads