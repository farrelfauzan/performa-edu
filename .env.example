# ===========================================
# Environment Configuration for Performa-Edu
# ===========================================

# Application Environment
NODE_ENV=development

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=performa_edu_db
POSTGRES_PORT=5432

# Database URL (auto-constructed in Docker, set manually for local dev)
# For local development: postgresql://postgres:postgres@localhost:5432/performa_edu_db?schema=public
# For Docker: postgresql://postgres:postgres@postgres:5432/performa_edu_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/performa_edu_db?schema=public"

# Prisma Configuration
PRISMA_CLI_QUERY_ENGINE_TYPE=binary

# ===========================================
# API Gateway Configuration
# ===========================================
API_GATEWAY_PORT=3000

# ===========================================
# gRPC Microservices Configuration
# ===========================================
# Auth Service
AUTH_SERVICE_GRPC_HOST=localhost
AUTH_SERVICE_GRPC_PORT=50051

# Content Service
CONTENT_SERVICE_GRPC_HOST=localhost
CONTENT_SERVICE_GRPC_PORT=50052

# Teacher Service
TEACHER_SERVICE_GRPC_HOST=localhost
TEACHER_SERVICE_GRPC_PORT=50053

# ===========================================
# Authentication (JWT)
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# Redis Configuration
# ===========================================
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=performa-assets

# Optional: Redis for caching/sessions
# REDIS_URL=redis://localhost:6379

# ===========================================
# Optional: Email configuration
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ===========================================
# Optional: File upload configuration
# ===========================================
# MAX_FILE_SIZE=10485760  # 10MB
# UPLOAD_DIR=uploads