generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  WAITING_REVIEW
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum ProgressAction {
  COMPLETE_SECTION
  ANSWER_QUESTION
}

// Auth Models
model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  username            String               @unique
  password            String
  active              ActiveStatus         @default(ACTIVE)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?            @map("deleted_at") @db.Timestamptz
  UserOnRole          UsersOnRoles[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Role {
  id          String         @id @default(cuid())
  name        String         @unique
  permissions Json[]         @default([])
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz
  UserOnRole  UsersOnRoles[]

  @@map("roles")
}

model UsersOnRoles {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@id([userId, roleId])
  @@map("users_on_roles")
}

// User Management Models
model Admin {
  id                String       @id @default(cuid())
  uniqueId          String       @unique @map("unique_id")
  userId            String       @unique @map("user_id")
  email             String       @unique
  profilePictureUrl String?       @map("profile_picture_url") @db.VarChar(500)
  active            ActiveStatus @default(ACTIVE)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz

  @@map("admins")
}

model Customer {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  uniqueId          String    @unique @map("unique_id")
  fullName          String    @map("full_name")
  phoneNumber       String    @map("phone_number") @db.VarChar(15)
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  profilePictureUrl String?    @map("profile_picture_url") @db.VarChar(500)
  bio               String?   @map("bio") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  @@map("customers")
}

model Student {
  id                String       @id @default(cuid())
  userId            String       @unique @map("user_id")
  uniqueId          String       @unique @map("unique_id")
  fullName          String       @map("full_name")
  phoneNumber       String?      @map("phone_number") @db.VarChar(15)
  dateOfBirth       DateTime?    @map("date_of_birth") @db.Date
  profilePictureUrl String?      @map("profile_picture_url") @db.VarChar(500)
  bio               String?      @db.Text
  active            ActiveStatus @default(ACTIVE)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz

  assignments       Assignment[]

  @@map("students")
}

model Assignment {
  id          String           @id @default(cuid())
  teacherId   String           @map("teacher_id")
  studentId   String           @map("student_id")
  contentId   String           @map("content_id")
  status      AssignmentStatus @default(ASSIGNED)
  progress    Float            @default(0)
  dueDate     DateTime?        @map("due_date") @db.Timestamptz
  assignedAt  DateTime         @default(now()) @map("assigned_at") @db.Timestamptz
  startedAt   DateTime?        @map("started_at") @db.Timestamptz
  completedAt DateTime?        @map("completed_at") @db.Timestamptz
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  student     Student          @relation(fields: [studentId], references: [id])
  progressLogs ProgressLog[]

  @@unique([studentId, contentId])
  @@index([teacherId])
  @@index([contentId])
  @@map("assignments")
}

model ProgressLog {
  id           String         @id @default(cuid())
  assignmentId String         @map("assignment_id")
  sectionId    String?        @map("section_id")
  questionId   String?        @map("question_id")
  action       ProgressAction
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz

  assignment   Assignment     @relation(fields: [assignmentId], references: [id])

  @@unique([assignmentId, sectionId, action])
  @@unique([assignmentId, questionId, action])
  @@index([assignmentId])
  @@map("progress_logs")
}

// Content Models
model Content {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  categoryId    String?          @map("category_id")
  title         String           @db.VarChar(255)
  year          Int              @db.SmallInt
  body          String           @db.Text
  thumbnailUrl  String?          @map("thumbnail_url") @db.VarChar(500)
  previewUrl    String?          @map("preview_url") @db.VarChar(500)
  status        ContentStatus    @default(DRAFT)
  publishedAt   DateTime?        @map("published_at") @db.Timestamptz
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?        @map("deleted_at") @db.Timestamptz
  category      Category?        @relation(fields: [categoryId], references: [id])
  contentMedias ContentMedia[]
  sections      ContentSection[]

  @@index([userId])
  @@index([categoryId])
  @@map("contents")
}

model ContentSection {
  id          String         @id @default(cuid())
  contentId   String         @map("content_id")
  content     Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  title       String         @db.VarChar(255)
  description String?        @db.Text
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz
  medias      ContentMedia[]

  @@index([contentId])
  @@map("content_sections")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  contents  Content[]

  @@map("categories")
}

model ContentMedia {
  id               String                @id @default(cuid())
  contentId        String                @map("content_id")
  content          Content               @relation(fields: [contentId], references: [id], onDelete: Cascade)
  sectionId        String?               @map("section_id")
  section          ContentSection?       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  mediaType        MediaType             @map("media_type")
  originalUrl      String                @map("original_url") @db.VarChar(500)
  hlsUrl           String?               @map("hls_url") @db.VarChar(500)
  thumbnailUrl     String?               @map("thumbnail_url") @db.VarChar(500)
  previewUrl       String?               @map("preview_url") @db.VarChar(500)
  bucketName       String                @map("bucket_name") @db.VarChar(255)
  objectPath       String                @map("object_path") @db.VarChar(500)
  fileName          String                 @map("file_name") @db.VarChar(255)
  fileSize          BigInt                 @map("file_size")
  mimeType         String                @map("mime_type") @db.VarChar(100)
  duration         Int? // Duration in seconds (for video/audio)
  width            Int? // Width in pixels (for image/video)
  height           Int? // Height in pixels (for image/video)
  processingStatus MediaProcessingStatus @default(PENDING) @map("processing_status")
  processedAt      DateTime?             @map("processed_at") @db.Timestamptz
  sortOrder        Int                   @default(0) @map("sort_order")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?             @map("deleted_at") @db.Timestamptz

  @@index([contentId])
  @@index([sectionId])
  @@index([processingStatus])
  @@map("content_media")
}
