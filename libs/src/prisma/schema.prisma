generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Auth Models
model User {
  id         String         @id @default(cuid())
  email      String         @unique
  username   String         @unique
  password   String
  active     ActiveStatus   @default(ACTIVE)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime?      @map("deleted_at") @db.Timestamptz
  UserOnRole UsersOnRoles[]

  @@map("users")
}

model Role {
  id          String         @id @default(cuid())
  name        String         @unique
  permissions Json[]         @default([])
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz
  UserOnRole  UsersOnRoles[]

  @@map("roles")
}

model UsersOnRoles {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@id([userId, roleId])
  @@map("users_on_roles")
}

// User Management Models
model Admin {
  id                String       @id @default(cuid())
  uniqueId          String       @unique @map("unique_id")
  userId            String       @unique @map("user_id")
  email             String       @unique
  profilePictureUrl String?      @map("profile_picture_url") @db.VarChar(500)
  active            ActiveStatus @default(ACTIVE)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz

  @@map("admins")
}

model Customer {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  uniqueId          String    @unique @map("unique_id")
  fullName          String    @map("full_name")
  phoneNumber       String    @map("phone_number") @db.VarChar(15)
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  profilePictureUrl String?   @map("profile_picture_url") @db.VarChar(500)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  @@map("customers")
}

// Content Models
model Content {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  title         String         @db.VarChar(255)
  body          String         @db.Text
  status        ContentStatus  @default(DRAFT)
  publishedAt   DateTime?      @map("published_at") @db.Timestamptz
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz
  contentMedias ContentMedia[]

  @@index([userId])
  @@map("contents")
}

model ContentMedia {
  id               String                @id @default(cuid())
  contentId        String                @map("content_id")
  content          Content               @relation(fields: [contentId], references: [id], onDelete: Cascade)
  mediaType        MediaType             @map("media_type")
  originalUrl      String                @map("original_url") @db.VarChar(500)
  hlsUrl           String?               @map("hls_url") @db.VarChar(500)
  thumbnailUrl     String?               @map("thumbnail_url") @db.VarChar(500)
  bucketName       String                @map("bucket_name") @db.VarChar(255)
  objectPath       String                @map("object_path") @db.VarChar(500)
  fileName         String                @map("file_name") @db.VarChar(255)
  fileSize         BigInt                @map("file_size")
  mimeType         String                @map("mime_type") @db.VarChar(100)
  duration         Int? // Duration in seconds (for video/audio)
  width            Int? // Width in pixels (for image/video)
  height           Int? // Height in pixels (for image/video)
  processingStatus MediaProcessingStatus @default(PENDING) @map("processing_status")
  processedAt      DateTime?             @map("processed_at") @db.Timestamptz
  sortOrder        Int                   @default(0) @map("sort_order")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?             @map("deleted_at") @db.Timestamptz

  @@index([contentId])
  @@index([processingStatus])
  @@map("content_media")
}
