generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  WAITING_REVIEW
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum MediaProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum ProgressAction {
  COMPLETE_SECTION
  ANSWER_QUESTION
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  MULTI_SELECT
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  TIMED_OUT
}

// Auth Models
model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  username            String               @unique
  password            String
  active              ActiveStatus         @default(ACTIVE)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?            @map("deleted_at") @db.Timestamptz
  UserOnRole          UsersOnRoles[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Role {
  id          String         @id @default(cuid())
  name        String         @unique
  permissions Json[]         @default([])
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz
  UserOnRole  UsersOnRoles[]

  @@map("roles")
}

model UsersOnRoles {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@id([userId, roleId])
  @@map("users_on_roles")
}

// User Management Models
model Admin {
  id                String       @id @default(cuid())
  uniqueId          String       @unique @map("unique_id")
  userId            String       @unique @map("user_id")
  email             String       @unique
  profilePictureUrl  String?      @map("profile_picture_url") @db.VarChar(500)
  branchId          String?      @map("branch_id")
  branchName        String?      @map("branch_name") @db.VarChar(255)
  active            ActiveStatus @default(ACTIVE)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz

  @@map("admins")
}

model Customer {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  uniqueId          String    @unique @map("unique_id")
  fullName          String    @map("full_name")
  phoneNumber       String    @map("phone_number") @db.VarChar(15)
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  profilePictureUrl  String?   @map("profile_picture_url") @db.VarChar(500)
  branchId          String?   @map("branch_id")
  branchName        String?   @map("branch_name") @db.VarChar(255)
  active            ActiveStatus @default(ACTIVE)
  bio               String?   @map("bio") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  classes  ClassTeacher[]
  branches BranchCustomer[]

  @@map("customers")
}

model Student {
  id                String       @id @default(cuid())
  userId            String       @unique @map("user_id")
  uniqueId          String       @unique @map("unique_id")
  fullName          String       @map("full_name")
  phoneNumber       String?      @map("phone_number") @db.VarChar(15)
  dateOfBirth       DateTime?    @map("date_of_birth") @db.Date
  profilePictureUrl String?      @map("profile_picture_url") @db.VarChar(500)
  bio               String?      @db.Text
  active            ActiveStatus @default(ACTIVE)
  branchId          String?      @map("branch_id")
  branchName        String?      @map("branch_name") @db.VarChar(255)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz

  branch      Branch?        @relation(fields: [branchId], references: [id])
  assignments Assignment[]
  classes     ClassStudent[]

  @@index([branchId])
  @@map("students")
}

model Assignment {
  id          String           @id @default(cuid())
  teacherId   String           @map("teacher_id")
  studentId   String           @map("student_id")
  contentId   String           @map("content_id")
  status      AssignmentStatus @default(ASSIGNED)
  progress    Float            @default(0)
  dueDate     DateTime?        @map("due_date") @db.Timestamptz
  assignedAt  DateTime         @default(now()) @map("assigned_at") @db.Timestamptz
  startedAt   DateTime?        @map("started_at") @db.Timestamptz
  completedAt DateTime?        @map("completed_at") @db.Timestamptz
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  student      Student       @relation(fields: [studentId], references: [id])
  progressLogs ProgressLog[]

  @@unique([studentId, contentId])
  @@index([teacherId])
  @@index([contentId])
  @@map("assignments")
}

model ProgressLog {
  id           String         @id @default(cuid())
  assignmentId String         @map("assignment_id")
  sectionId    String?        @map("section_id")
  questionId   String?        @map("question_id")
  action       ProgressAction
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz

  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@unique([assignmentId, sectionId, action])
  @@unique([assignmentId, questionId, action])
  @@index([assignmentId])
  @@map("progress_logs")
}

// Content Models
model Content {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  categoryId    String?          @map("category_id")
  title         String           @db.VarChar(255)
  year          Int              @db.SmallInt
  body          String           @db.Text
  thumbnailUrl  String?          @map("thumbnail_url") @db.VarChar(500)
  previewUrl    String?          @map("preview_url") @db.VarChar(500)
  status        ContentStatus    @default(DRAFT)
  publishedAt   DateTime?        @map("published_at") @db.Timestamptz
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?        @map("deleted_at") @db.Timestamptz
  category      Category?        @relation(fields: [categoryId], references: [id])
  contentMedias ContentMedia[]
  sections      ContentSection[]

  @@index([userId])
  @@index([categoryId])
  @@map("contents")
}

model ContentSection {
  id          String         @id @default(cuid())
  contentId   String         @map("content_id")
  content     Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  title       String         @db.VarChar(255)
  description String?        @db.Text
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz
  medias      ContentMedia[]

  @@index([contentId])
  @@map("content_sections")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  contents  Content[]

  @@map("categories")
}

model ContentMedia {
  id               String                @id @default(cuid())
  contentId        String                @map("content_id")
  content          Content               @relation(fields: [contentId], references: [id], onDelete: Cascade)
  sectionId        String?               @map("section_id")
  section          ContentSection?       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  mediaType        MediaType             @map("media_type")
  originalUrl      String                @map("original_url") @db.VarChar(500)
  hlsUrl           String?               @map("hls_url") @db.VarChar(500)
  thumbnailUrl     String?               @map("thumbnail_url") @db.VarChar(500)
  previewUrl       String?               @map("preview_url") @db.VarChar(500)
  bucketName       String                @map("bucket_name") @db.VarChar(255)
  objectPath       String                @map("object_path") @db.VarChar(500)
  fileName         String                @map("file_name") @db.VarChar(255)
  fileSize         BigInt                @map("file_size")
  mimeType         String                @map("mime_type") @db.VarChar(100)
  duration         Int? // Duration in seconds (for video/audio)
  width            Int? // Width in pixels (for image/video)
  height           Int? // Height in pixels (for image/video)
  processingStatus MediaProcessingStatus @default(PENDING) @map("processing_status")
  processedAt      DateTime?             @map("processed_at") @db.Timestamptz
  sortOrder        Int                   @default(0) @map("sort_order")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?             @map("deleted_at") @db.Timestamptz

  @@index([contentId])
  @@index([sectionId])
  @@index([processingStatus])
  @@map("content_media")
}

// Quiz Models
model Quiz {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  title            String    @db.VarChar(255)
  description      String?   @db.Text
  timeLimitSecs    Int?      @map("time_limit_secs")
  passingScore     Int       @default(70) @map("passing_score")
  maxAttempts      Int       @default(3) @map("max_attempts")
  shuffleQuestions Boolean   @default(false) @map("shuffle_questions")
  isPublished      Boolean   @default(false) @map("is_published")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  questions Question[]
  attempts  QuizAttempt[]

  @@index([userId])
  @@map("quizzes")
}

model Question {
  id          String       @id @default(cuid())
  quizId      String       @map("quiz_id")
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type        QuestionType
  text        String       @db.Text
  explanation String?      @db.Text
  pictureUrl  String?      @map("picture_url")
  points      Int          @default(1)
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  options QuestionOption[]
  answers AttemptAnswer[]

  @@index([quizId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String   @db.Text
  isCorrect  Boolean  @default(false) @map("is_correct")
  sortOrder  Int      @default(0) @map("sort_order")

  @@index([questionId])
  @@map("question_options")
}

model QuizAttempt {
  id          String        @id @default(cuid())
  quizId      String        @map("quiz_id")
  quiz        Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id")
  score       Float?
  totalPoints Int?          @map("total_points")
  status      AttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now()) @map("started_at") @db.Timestamptz
  submittedAt DateTime?     @map("submitted_at") @db.Timestamptz

  answers AttemptAnswer[]

  @@index([quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

model AttemptAnswer {
  id              String      @id @default(cuid())
  attemptId       String      @map("attempt_id")
  attempt         QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String      @map("question_id")
  question        Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptions String[]    @map("selected_options")
  textAnswer      String?     @map("text_answer") @db.Text
  isCorrect       Boolean     @default(false) @map("is_correct")
  pointsEarned    Float       @default(0) @map("points_earned")

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("attempt_answers")
}

// Branch Models
model Branch {
  id        String    @id @default(cuid())
  name      String    @unique
  address   String?   @db.Text
  phone     String?   @map("phone") @db.VarChar(15)
  adminId   String    @map("admin_id")
  adminName String    @map("admin_name") @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  classes   Class[]
  students  Student[]
  customers BranchCustomer[]

  @@map("branches")
}

model BranchCustomer {
  id         String   @id @default(cuid())
  branchId   String   @map("branch_id")
  customerId String   @map("customer_id")
  joinedAt   DateTime @default(now()) @map("joined_at") @db.Timestamptz

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([branchId, customerId])
  @@index([branchId])
  @@index([customerId])
  @@map("branch_customers")
}

// Class Models
model Class {
  id          String       @id @default(cuid())
  uniqueId    String       @unique @map("unique_id")
  createdBy   String       @map("created_by")
  branchId    String?      @map("branch_id")
  name        String       @db.VarChar(255)
  description String?      @db.Text
  active      ActiveStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz

  branch   Branch?        @relation(fields: [branchId], references: [id])
  teachers ClassTeacher[]
  students ClassStudent[]

  @@index([createdBy])
  @@index([branchId])
  @@map("classes")
}

model ClassTeacher {
  id         String   @id @default(cuid())
  classId    String   @map("class_id")
  customerId String   @map("customer_id")
  joinedAt   DateTime @default(now()) @map("joined_at") @db.Timestamptz

  class    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([classId, customerId])
  @@index([classId])
  @@index([customerId])
  @@map("class_teachers")
}

model ClassStudent {
  id        String   @id @default(cuid())
  classId   String   @map("class_id")
  studentId String   @map("student_id")
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
  @@map("class_students")
}
