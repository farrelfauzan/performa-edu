# ===========================================
# Production Environment Configuration
# ===========================================
# Copy this file and set values for your production environment
# These are used by Cloud Run deployment scripts
# ===========================================

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1

# Application Environment
NODE_ENV=production

# ===========================================
# API Gateway Configuration
# ===========================================
PORT=3000

# ===========================================
# gRPC Microservices URLs (set by Cloud Run)
# ===========================================
# These are automatically configured during deployment
# AUTH_SERVICE_GRPC_HOST=auth-service-xxxx-xx.a.run.app
# AUTH_SERVICE_GRPC_PORT=443
# CONTENT_SERVICE_GRPC_HOST=content-service-xxxx-xx.a.run.app
# CONTENT_SERVICE_GRPC_PORT=443
# CUSTOMER_SERVICE_GRPC_HOST=customer-service-xxxx-xx.a.run.app
# CUSTOMER_SERVICE_GRPC_PORT=443

# ===========================================
# Database (Cloud SQL)
# ===========================================
# This is stored in Secret Manager and injected by Cloud Run
# Format: postgresql://user:password@localhost:5432/dbname?host=/cloudsql/project:region:instance
# DATABASE_URL=stored-in-secret-manager

# ===========================================
# Authentication (JWT)
# ===========================================
# These are stored in Secret Manager and injected by Cloud Run
# JWT_SECRET=stored-in-secret-manager
# JWT_REFRESH_SECRET=stored-in-secret-manager
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# Redis (Memorystore)
# ===========================================
# This is stored in Secret Manager and injected by Cloud Run
# REDIS_URL=stored-in-secret-manager

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGIN=https://your-frontend-domain.com

# ===========================================
# Cloud Run Specific
# ===========================================
# Min/max instances (0 enables scale-to-zero)
MIN_INSTANCES=0
MAX_INSTANCES=10

# Resource limits
MEMORY=512Mi
CPU=1
